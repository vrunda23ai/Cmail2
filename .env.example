# ============================================================
# CMAIL - Environment Variables (copy to .env.local for local dev)
# ============================================================

# --- Supabase (from https://app.supabase.com/project/_/settings/api) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (optional; only if you use a non-Supabase Gmail flow) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- AI Provider ---
# Pick ONE of: grok | groq | hf | openai
# groq  = Groq Cloud (FREE tier, fastest, recommended)
# grok  = xAI Grok (paid, needs credits)
# hf    = Hugging Face (rate-limited, sometimes slow)
# openai = OpenAI (pay per token)
AI_PROVIDER=groq

# --- Groq (FREE, https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_your-key
GROQ_MODEL=llama-3.1-8b-instant

# --- Grok / xAI (https://console.x.ai) ---
GROK_API_KEY=xai-your-key
GROK_MODEL=grok-2-latest

# --- Hugging Face (https://huggingface.co/settings/tokens) ---
HF_API_KEY=hf_your-token
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# --- App URL (used for OAuth redirects) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
